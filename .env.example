# Required
ANTHROPIC_API_KEY=sk-ant-...
CARAPACE_TOKEN=pick-a-secret-bearer-token

# Optional — LLM providers
# GOOGLE_API_KEY=

# Optional — Matrix channel
# CARAPACE_MATRIX_PASSWORD=

# Optional — Git remote token
# CARAPACE_GIT_TOKEN=

# Optional — Bitwarden sidecar (start with: docker compose up -d --scale bw=1)
# BW_SERVER_URL=https://vault.example.com
# BW_CLIENTID=user.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# BW_CLIENTSECRET=xxxxxxxxxxxxxxxxxxxx
# BW_MASTER_PASSWORD=

# Docker socket GID (auto-detected on most systems)
# DOCKER_GID=0
