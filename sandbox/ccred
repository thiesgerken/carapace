#!/usr/bin/env python3
"""ccred — credential helper for Carapace sandbox containers.

Talks to the Carapace REST API via CARAPACE_API_URL to list and fetch
credentials from the configured vault backends.

Usage:
    ccred list [-q QUERY]
    ccred get <vault_path> [-o FILE]
"""

from __future__ import annotations

import argparse
import json
import os
import sys
import time
import urllib.error
import urllib.request


def _api_url() -> str:
    url = os.environ.get("CARAPACE_API_URL")
    if not url:
        print("error: CARAPACE_API_URL not set", file=sys.stderr)
        sys.exit(1)
    return url.rstrip("/")


def _request(path: str, *, retries: int = 0, delay: float = 2.0) -> urllib.request.Request:
    return urllib.request.Request(f"{_api_url()}{path}")


def cmd_list(args: argparse.Namespace) -> None:
    path = "/credentials"
    if args.query:
        path += f"?q={urllib.request.quote(args.query)}"
    try:
        with urllib.request.urlopen(_request(path)) as resp:
            data = json.loads(resp.read())
    except urllib.error.HTTPError as e:
        print(f"error: {e.code} {e.reason}", file=sys.stderr)
        sys.exit(1)

    if not data:
        print("No credentials found.")
        return

    for cred in data:
        line = cred.get("name", cred.get("vault_path", "?"))
        desc = cred.get("description", "")
        vp = cred.get("vault_path", "")
        if desc:
            print(f"{line} ({vp}) — {desc}")
        else:
            print(f"{line} ({vp})")


def cmd_get(args: argparse.Namespace) -> None:
    vault_path = args.vault_path
    path = f"/credentials/{vault_path}"

    max_wait = 300
    start = time.monotonic()
    while True:
        try:
            with urllib.request.urlopen(_request(path), timeout=max_wait) as resp:
                value = resp.read().decode()
        except urllib.error.HTTPError as e:
            if e.code == 403:
                print("error: credential request denied by user", file=sys.stderr)
                sys.exit(1)
            if e.code == 404:
                print(f"error: credential not found: {vault_path}", file=sys.stderr)
                sys.exit(1)
            if e.code == 202:
                elapsed = time.monotonic() - start
                if elapsed > max_wait:
                    print("error: timed out waiting for approval", file=sys.stderr)
                    sys.exit(1)
                time.sleep(2)
                continue
            print(f"error: {e.code} {e.reason}", file=sys.stderr)
            sys.exit(1)
        break

    if args.output:
        fd = os.open(args.output, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o400)
        with os.fdopen(fd, "w") as f:
            f.write(value)
        print(f"Written to {args.output}", file=sys.stderr)
    else:
        sys.stdout.write(value)


def main() -> None:
    parser = argparse.ArgumentParser(prog="ccred", description="Carapace credential helper")
    sub = parser.add_subparsers(dest="command", required=True)

    ls = sub.add_parser("list", help="List available credentials")
    ls.add_argument("-q", "--query", default="", help="Filter by name/description")

    get = sub.add_parser("get", help="Fetch a credential value")
    get.add_argument("vault_path", help="Vault path (e.g. dev/gmail)")
    get.add_argument("-o", "--output", help="Write value to file instead of stdout")

    args = parser.parse_args()
    if args.command == "list":
        cmd_list(args)
    elif args.command == "get":
        cmd_get(args)


if __name__ == "__main__":
    main()
