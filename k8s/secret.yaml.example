# Template — DO NOT commit real values. Create via:
# kubectl create secret generic carapace-secrets -n carapace \
#   --from-literal=ANTHROPIC_API_KEY=sk-... \
#   --from-literal=CARAPACE_MATRIX_PASSWORD=...
apiVersion: v1
kind: Secret
metadata:
  name: carapace-secrets
  namespace: carapace
type: Opaque
stringData:
  ANTHROPIC_API_KEY: "REPLACE_ME"
  # CARAPACE_MATRIX_PASSWORD: ""
